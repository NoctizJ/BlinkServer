{
  "webhooks": [
    {
      "path": "/webhook/sample",
      "module": "jobs.sample_job",
      "function": "run",
      "require_secret": false
    },
    {
      "path": "/webhook/blink/arm",
      "module": "jobs.home_assistant_arm_disarm",
      "function": "run",
      "require_secret": true
    },
    {
      "path": "/webhook/log",
      "module": "jobs.log_webhook",
      "function": "run",
      "require_secret": true
    },
    {
      "path": "/webhook/upload",
      "module": "jobs.file_upload",
      "function": "run",
      "require_secret": true
    },
    {
      "path": "/webhook/notify/leaving",
      "module": "jobs.notify_phone",
      "function": "leaving_home",
      "require_secret": true
    },
    {
      "path": "/webhook/notify/arriving",
      "module": "jobs.notify_phone",
      "function": "arriving_home",
      "require_secret": true
    }
  ]
}
